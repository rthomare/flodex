# Vercel only needs the dashboard + its workspace deps. Everything below is
# either irrelevant (Rust, contracts) or regenerated by the install step
# (node_modules, .next, etc.).

# Rust build artifacts — massive (~GB)
target/
**/target/

# Node + Next.js build artifacts — Vercel rebuilds these
node_modules/
**/node_modules/
.next/
**/.next/
dist/
**/dist/

# Foundry artifacts (libs are vendored under contracts/lib; not needed by dashboard)
contracts/lib/
contracts/out/
contracts/cache/
contracts/broadcast/

# Local state
.env
.env.*
*.log
.DS_Store

# Editor
.idea/
.vscode/
*.swp

# Git
.git/
