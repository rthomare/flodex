{
  "name": "flodex",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/client",
    "apps/dashboard",
    "packages/*",
    "tests/e2e"
  ],
  "scripts": {
    "dev": "./scripts/dev.sh",
    "dev:kill": "./scripts/dev.sh --kill",
    "deploy": "./scripts/deploy.sh",
    "dash": "bun run --cwd apps/dashboard dev",
    "client": "bun run --cwd apps/client start",
    "gen:types": "cargo test -p protocol export_bindings --quiet",
    "test:e2e": "bun run --cwd tests/e2e test"
  }
}
