# Copy to `.env` and fill in. `.env` is gitignored.

# Required for any deploy target ----------------------------------------------

# Hex private key of the deployer account. Must be funded with native gas on
# the target network (Sepolia ETH for Base Sepolia, real ETH on Base mainnet).
# DO NOT commit. Use a fresh key for testnets, never share a mainnet key.
PRIVATE_KEY=0x

# Minimum stake nodes must lock when registering, in raw USDC units (6 decimals).
# 100 USDC = 100000000.
MIN_STAKE=100000000

# Seconds after openSession before the client can unilaterally reclaim a stuck
# session. 1 hour = 3600 on testnet; consider 24h+ on mainnet.
RECLAIM_TIMEOUT=3600

# RPC endpoints (per-chain) ---------------------------------------------------

# Base Sepolia. The default public endpoint works fine for low traffic; for
# heavier deploys point at Alchemy / Infura.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Base mainnet. Same caveat.
BASE_RPC_URL=https://mainnet.base.org

# Optional --------------------------------------------------------------------

# If unset, the deploy script deploys MockUSDC (devnet only).
# Base Sepolia (Circle): 0x036CbD53842c5426634e7929541eC2318f3dCF7e
# Base mainnet (Circle): 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# USDC_ADDRESS=

# Registry owner (slasher / config). Defaults to deployer if unset. Set to a
# multisig for mainnet.
# OWNER=

# Etherscan/Basescan API key for `forge verify-contract`. Optional; verification
# can also be run separately.
# BASESCAN_API_KEY=
