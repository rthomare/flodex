# Copy to `.env.local` for local dev. `.env.local` is gitignored by Next.js.
# `NEXT_PUBLIC_*` values are inlined into the client bundle at build time.

# Default coordinator URL the dashboard talks to. Local dev keeps the
# localhost fallback if this is unset; the Vercel deployment should set this
# to the hosted coordinator URL via project env vars (Project Settings →
# Environment Variables).
# NEXT_PUBLIC_COORDINATOR_URL=https://flodex-dry-sun-2419.fly.dev
